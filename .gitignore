# =============================================================
# Food Delivery Platform — Microservices workspace .gitignore
# =============================================================

# ---- Java / Maven ----
target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# Maven wrapper bits we DO want to track:
#   mvnw, mvnw.cmd, .mvn/wrapper/maven-wrapper.properties
# Bits we do NOT want to track:
.mvn/wrapper/maven-wrapper.jar

# ---- IDE: IntelliJ IDEA ----
.idea/
*.iml
*.iws
*.ipr
out/

# ---- IDE: VS Code ----
.vscode/
*.code-workspace

# ---- IDE: Eclipse / STS ----
.classpath
.project
.settings/
.factorypath
.apt_generated/
.springBeans

# ---- OS: macOS ----
.DS_Store
.AppleDouble
.LSOverride

# ---- OS: Windows ----
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Logs ----
*.log
logs/
log/

# ---- Docker / runtime data ----
# Local DB volumes mounted by docker-compose
data/
postgres-data/
rabbitmq-data/

# ---- Local secrets / env overrides ----
.env
.env.local
*.env.local
application-local.yml
application-secret.yml

# ---- Test / coverage output ----
*.exec
coverage/
jacoco.exec

# ---- Spring Boot devtools restart marker ----
.spring-boot-devtools.properties
