# =============================================================
# Local override file — copy to `.env` and adjust as needed.
# `.env` is gitignored so secrets stay local.
# =============================================================

# JWT signing secret. MUST match across customer-service (issuer)
# and api-gateway (verifier). A safe random string of >= 32 chars.
JWT_SECRET=dev-only-jwt-secret-do-not-use-in-production-min-256-bits-required

# RabbitMQ credentials. The dedicated user (not 'guest') so connections
# from other containers are accepted.
RABBITMQ_USER=fooddelivery
RABBITMQ_PASSWORD=fooddelivery
